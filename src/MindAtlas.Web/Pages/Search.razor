@page "/search"
@inject HttpClient Http
@inject PageStateService PageState
@implements IDisposable

<PageTitle>@L["search.page_title"]</PageTitle>

<h1>@L["search.title"]</h1>

<input class="search-box" type="text" placeholder="@L["search.placeholder"]"
       @bind="_query" @bind:event="oninput" @bind:after="OnSearchAsync" />

<div class="search-results">
    @if (_searching)
    {
        <p class="loading">@L["search.searching"]</p>
    }
    else if (_results is not null && _results.Count == 0 && !string.IsNullOrWhiteSpace(_query))
    {
        <p class="empty-state">@L.Format("search.no_results", _query)</p>
    }
    else if (_results is not null)
    {
        <div class="card-grid">
            @foreach (var entry in _results)
            {
                <div class="card">
                    <h3><a href="wiki/@Uri.EscapeDataString(entry.PageName)">@entry.PageName</a></h3>
                    <p class="summary">@entry.Summary</p>
                    <div class="tags">
                        @foreach (var tag in entry.Tags)
                        {
                            <span class="tag">@tag</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private const string StateKey = "search";

    private string _query = "";
    private List<IndexEntry>? _results;
    private bool _searching;
    private CancellationTokenSource? _debounce;

    protected override void OnInitialized()
    {
        if (PageState.TryGet<SearchState>(StateKey, out var saved) && saved is not null)
        {
            _query = saved.Query;
            _results = saved.Results;
        }
    }

    public void Dispose()
    {
        _debounce?.Cancel();
        PageState.Save(StateKey, new SearchState(_query, _results));
    }

    private async Task OnSearchAsync()
    {
        _debounce?.Cancel();

        if (string.IsNullOrWhiteSpace(_query))
        {
            _results = null;
            return;
        }

        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;

        try
        {
            await Task.Delay(300, token);
            _searching = true;
            StateHasChanged();

            _results = await Http.GetFromJsonAsync<List<IndexEntry>>(
                $"api/wiki/search?q={Uri.EscapeDataString(_query)}", token) ?? [];
        }
        catch (TaskCanceledException) { }
        catch
        {
            _results = [];
        }
        finally
        {
            _searching = false;
        }
    }

    private sealed record SearchState(string Query, List<IndexEntry>? Results);
}
