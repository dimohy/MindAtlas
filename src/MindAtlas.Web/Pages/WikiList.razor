@page "/wiki"
@inject HttpClient Http

<PageTitle>@L["wiki.page_title"]</PageTitle>

<h1>@L["wiki.title"]</h1>

@if (_entries is null)
{
    <p class="loading">@L["common.loading"]</p>
}
else if (_entries.Count == 0)
{
    <div class="empty-state">
        <p>@L["wiki.empty"]</p>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var entry in _entries)
        {
            <div class="card">
                <h3><a href="wiki/@Uri.EscapeDataString(entry.PageName)">@entry.PageName</a></h3>
                <p class="summary">@entry.Summary</p>
                <div class="tags">
                    @foreach (var tag in entry.Tags)
                    {
                        <span class="tag">@tag</span>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private List<IndexEntry>? _entries;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _entries = await Http.GetFromJsonAsync<List<IndexEntry>>("api/wiki") ?? [];
        }
        catch
        {
            _entries = [];
        }
    }
}
