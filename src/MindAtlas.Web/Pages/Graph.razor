@page "/graph"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@L["graph.page_title"]</PageTitle>

<h1>@L["graph.title"]</h1>

@if (_loading)
{
    <p class="loading">@L["graph.loading"]</p>
}
else if (_empty)
{
    <div class="empty-state">
        <p>@L["graph.empty"]</p>
    </div>
}
else
{
    <div id="graph-container" class="graph-container"></div>
}

@code {
    private bool _loading = true;
    private bool _empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var response = await Http.GetAsync("api/wiki/graph");
            if (!response.IsSuccessStatusCode)
            {
                _empty = true;
                _loading = false;
                StateHasChanged();
                return;
            }

            var json = await response.Content.ReadAsStringAsync();

            // Inject D3.js if not already loaded, then render graph
            await JS.InvokeVoidAsync("mindAtlasGraph.render", json);

            _loading = false;
            StateHasChanged();
        }
        catch
        {
            _empty = true;
            _loading = false;
            StateHasChanged();
        }
    }
}
