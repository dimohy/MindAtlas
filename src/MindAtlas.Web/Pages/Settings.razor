@page "/settings"
@inject HttpClient Http
@inject ThemeService Theme
@implements IAsyncDisposable

<PageTitle>@L["settings.page_title"]</PageTitle>

<h1>@L["settings.title"]</h1>

<div class="settings-section">
    <h2>@L["settings.section_language"]</h2>
    <div class="setting-row-group">
        <div class="setting-row">
            <label>@L["settings.label_ui_language"]</label>
            <select @bind="_uiLanguage" @bind:after="OnUiLanguageChangedAsync" class="setting-input">
                <option value="en">English</option>
                <option value="ko">한국어</option>
                <option value="ja">日本語</option>
            </select>
            <span class="setting-hint">@L["settings.hint_ui_language"]</span>
        </div>
        @if (_uiLanguageAutoDetected)
        {
            <div class="setting-warning">
                <span class="setting-warning-icon">⚠</span>
                <span>@L["settings.hint_auto_detected"]</span>
            </div>
        }
    </div>
    <div class="setting-row-group">
        <div class="setting-row">
            <label>@L["settings.label_ingest_language"]</label>
            <select @bind="_ingestLanguage" class="setting-input">
                <option value="en">English</option>
                <option value="ko">한국어</option>
                <option value="ja">日本語</option>
            </select>
            <span class="setting-hint">@L["settings.hint_ingest_language"]</span>
        </div>
        @if (_ingestLanguageAutoDetected)
        {
            <div class="setting-warning">
                <span class="setting-warning-icon">⚠</span>
                <span>@L["settings.hint_auto_detected"]</span>
            </div>
        }
    </div>
</div>

<div class="settings-section">
    <h2>@L["settings.section_data"]</h2>
    <div class="setting-row">
        <label>@L["settings.label_data_root"]</label>
        <input type="text" @bind="_dataRoot" placeholder="~/MindAtlas" class="setting-input" />
    </div>
</div>

<div class="settings-section">
    <h2>@L["settings.section_hotkey"]</h2>
    <div class="setting-row">
        <label>@L["settings.label_toggle_window"]</label>
        <input type="text" @bind="_hotkey" placeholder="Ctrl+Shift+Space" class="setting-input" readonly />
        <span class="setting-hint">@L["settings.hint_hotkey"]</span>
    </div>
</div>

<div class="settings-section">
    <h2>@L["settings.section_llm"]</h2>
    <div class="setting-row">
        <label>@L["settings.label_model"]</label>
        <select @bind="_model" class="setting-input">
            <option value="gpt-5-mini">GPT-5 mini (OpenAI)</option>
        </select>
    </div>
    <div class="setting-row">
        <label>@L["settings.label_github_token"]</label>
        <input type="password" @bind="_githubToken" @bind:event="oninput"
               placeholder="@(_githubTokenConfigured ? L["settings.github_token_placeholder_set"] : L["settings.github_token_placeholder_empty"])"
               class="setting-input" autocomplete="off" spellcheck="false" />
        <button class="btn-secondary" @onclick="TestGitHubTokenAsync" disabled="@_githubTokenTesting">
            @(_githubTokenTesting ? L["settings.github_token_testing"] : L["settings.github_token_test"])
        </button>
    </div>
    <div class="setting-row setting-row-hint">
        <span class="setting-hint">@L["settings.hint_github_token"]</span>
        @if (!string.IsNullOrEmpty(_githubTokenStatus))
        {
            <span class="@(_githubTokenStatusOk ? "token-status-ok" : "token-status-err")">
                @_githubTokenStatus
            </span>
        }
    </div>
</div>

<div class="settings-section">
    <h2>@L["settings.section_ai_query"]</h2>
    <div class="setting-row">
        <label>
            <input type="checkbox" @bind="_webSearchDefaultEnabled" />
            @L["settings.label_web_search_default"]
        </label>
        <span class="setting-hint">@L["settings.hint_web_search_default"]</span>
    </div>
    <div class="setting-row">
        <label>
            <input type="checkbox" @bind="_autoSaveUncovered" />
            @L["settings.label_auto_save_uncovered"]
        </label>
        <span class="setting-hint">@L["settings.hint_auto_save_uncovered"]</span>
    </div>
</div>

<div class="settings-section">
    <h2>@L["settings.section_auto_lint"]</h2>
    <div class="setting-row">
        <label>@L["settings.label_lint_schedule"]</label>
        <select @bind="_lintInterval" class="setting-input">
            <option value="0">@L["settings.lint_disabled"]</option>
            <option value="1">@L["settings.lint_every_hour"]</option>
            <option value="6">@L["settings.lint_every_6_hours"]</option>
            <option value="24">@L["settings.lint_daily"]</option>
        </select>
    </div>
</div>

<div class="settings-section">
    <h2>@L["settings.section_appearance"]</h2>
    <div class="setting-row">
        <label>@L["settings.label_theme"]</label>
        <select @bind="_theme" @bind:after="OnThemePreviewAsync" class="setting-input">
            <option value="light">@L["settings.theme_light"]</option>
            <option value="dark">@L["settings.theme_dark"]</option>
            <option value="auto">@L["settings.theme_auto"]</option>
        </select>
    </div>
</div>

<div class="settings-actions">
    <button class="btn-primary" @onclick="SaveSettings">@L["settings.btn_save"]</button>
    <span class="save-status">@_status</span>
</div>

@code {
    private string _uiLanguage = "en";
    private string _ingestLanguage = "en";
    private string _dataRoot = "~/MindAtlas";
    private string _hotkey = "Ctrl+Shift+Space";
    private string _model = "gpt-5-mini";
    private int _lintInterval = 0;
    private string _theme = "auto";
    private string _savedTheme = "auto";
    private bool _themeCommitted;
    private string _status = "";
    private bool _uiLanguageAutoDetected;
    private bool _ingestLanguageAutoDetected;
    private string _githubToken = "";
    private bool _githubTokenConfigured;
    private string _githubTokenStatus = "";
    private bool _githubTokenStatusOk;
    private bool _githubTokenTesting;
    private bool _webSearchDefaultEnabled;
    private bool _autoSaveUncovered;

    protected override async Task OnInitializedAsync()
    {
        _uiLanguage = L.CurrentLanguage;
        try
        {
            var settings = await Http.GetFromJsonAsync<AppSettingsDto>("api/settings");
            if (settings is not null)
            {
                _uiLanguage = settings.UiLanguage ?? "en";
                _ingestLanguage = settings.IngestLanguage ?? "en";
                _dataRoot = settings.DataRoot ?? "~/MindAtlas";
                _uiLanguageAutoDetected = settings.IsUiLanguageAutoDetected;
                _ingestLanguageAutoDetected = settings.IsIngestLanguageAutoDetected;
                if (!string.IsNullOrEmpty(settings.Model))
                    _model = settings.Model;
                if (!string.IsNullOrEmpty(settings.Theme))
                {
                    _theme = settings.Theme;
                    _savedTheme = settings.Theme;
                }
                _githubTokenConfigured = settings.IsGitHubTokenConfigured;
                _githubToken = settings.GitHubToken ?? "";
                _autoSaveUncovered = settings.AutoSaveUncovered;
                _webSearchDefaultEnabled = settings.WebSearchDefaultEnabled;
            }
        }
        catch
        {
            // Server unavailable — use defaults
        }

        // If MainLayout already overrode the UI language with the browser's
        // preferred language after first render, reflect that in the dropdown
        // instead of the desktop-detected value from the server.
        if (_uiLanguageAutoDetected && L.CurrentLanguage != _uiLanguage)
            _uiLanguage = L.CurrentLanguage;

        // Sync UI language with localization service
        if (_uiLanguage != L.CurrentLanguage)
            await L.SetLanguageAsync(_uiLanguage);
    }

    private async Task OnThemePreviewAsync()
    {
        await Theme.ApplyAsync(_theme);
    }

    private async Task OnUiLanguageChangedAsync()
    {
        await L.SetLanguageAsync(_uiLanguage);
    }

    private async Task SaveSettings()
    {
        _status = L["settings.status_saving"];
        StateHasChanged();

        try
        {
            var dto = new AppSettingsDto
            {
                UiLanguage = _uiLanguage,
                IngestLanguage = _ingestLanguage,
                DataRoot = _dataRoot,
                Model = _model,
                Theme = _theme,
                AutoSaveUncovered = _autoSaveUncovered,
                WebSearchDefaultEnabled = _webSearchDefaultEnabled,
                GitHubToken = _githubToken
            };
            var response = await Http.PutAsJsonAsync("api/settings", dto);
            if (response.IsSuccessStatusCode)
            {
                _status = $"✅ {L["settings.status_saved"]}";
                _savedTheme = _theme;
                _themeCommitted = true;
                // User just locked the choices — clear the auto-detected hint.
                _uiLanguageAutoDetected = false;
                _ingestLanguageAutoDetected = false;
            }
            else
            {
                _status = $"❌ {L["settings.status_save_failed"]}";
            }
        }
        catch
        {
            _status = $"❌ {L["settings.status_connection_error"]}";
        }

        StateHasChanged();
    }

    private sealed class AppSettingsDto
    {
        public string? UiLanguage { get; set; }
        public string? IngestLanguage { get; set; }
        public string? DataRoot { get; set; }
        public string? Model { get; set; }
        public string? Theme { get; set; }
        public string? GitHubToken { get; set; }
        public bool IsGitHubTokenConfigured { get; set; }
        public bool IsUiLanguageAutoDetected { get; set; }
        public bool AutoSaveUncovered { get; set; }
        public bool WebSearchDefaultEnabled { get; set; }
        public bool IsIngestLanguageAutoDetected { get; set; }
    }

    private sealed class TestTokenResultDto
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
    }

    private async Task TestGitHubTokenAsync()
    {
        _githubTokenTesting = true;
        _githubTokenStatus = "";
        StateHasChanged();
        try
        {
            var response = await Http.PostAsJsonAsync(
                "api/settings/test-copilot-token",
                new { token = _githubToken });
            if (!response.IsSuccessStatusCode)
            {
                _githubTokenStatusOk = false;
                _githubTokenStatus = $"❌ HTTP {(int)response.StatusCode}";
                return;
            }
            var result = await response.Content.ReadFromJsonAsync<TestTokenResultDto>();
            if (result is null)
            {
                _githubTokenStatusOk = false;
                _githubTokenStatus = "❌ " + L["settings.github_token_error_unknown"];
                return;
            }
            _githubTokenStatusOk = result.Success;
            _githubTokenStatus = result.Success
                ? $"✅ {L["settings.github_token_ok_prefix"]} {result.Message}"
                : $"❌ {result.Message}";
        }
        catch (Exception ex)
        {
            _githubTokenStatusOk = false;
            _githubTokenStatus = "❌ " + ex.Message;
        }
        finally
        {
            _githubTokenTesting = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        // If the user navigated away without saving, revert the live theme preview.
        if (!_themeCommitted && _theme != _savedTheme)
        {
            try { await Theme.ApplyAsync(_savedTheme); } catch { /* ignore */ }
        }
    }
}
