<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MindAtlas.Desktop.Views.QuickInputWindow"
        Title="MindAtlas — Quick Note"
        Width="500" Height="250"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True">

    <Grid Margin="16" RowDefinitions="*,Auto">
        <!-- Text input area -->
        <TextBox x:Name="NoteInput"
                 Grid.Row="0"
                 PlaceholderText="Type your note here... (Ctrl+Enter to save)"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top" />

        <!-- Bottom bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0" Spacing="8">
            <TextBlock x:Name="StatusText" Text=""
                       VerticalAlignment="Center" Foreground="Gray" FontSize="12" />
            <Button x:Name="SaveButton" Content="Save" Click="OnSaveClick"
                    Width="80" HorizontalContentAlignment="Center" />
        </StackPanel>
    </Grid>

</Window>
