<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MindAtlas.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="MindAtlas.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MindAtlas"
        Width="1024" Height="768"
        DragDrop.AllowDrop="True">

    <Grid>
        <!-- WebView for Blazor WASM -->
        <NativeWebView x:Name="WebView" />

        <!-- Drop overlay (hidden by default) -->
        <Border x:Name="DropOverlay" IsVisible="False"
                Background="#88000000" CornerRadius="12"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Drop files here to ingest"
                       Foreground="White" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>

</Window>
